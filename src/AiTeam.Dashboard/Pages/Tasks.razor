```razor
@page "/tasks"
@using AiTeam.Shared.Models
@using AiTeam.Shared.Services
@inject ICsvExportService CsvExportService
@inject IJSRuntime JSRuntime
@inject ILogger<Tasks> Logger

<PageTitle>任務列表</PageTitle>

<div class="container-fluid">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2 class="mb-0">任務列表</h2>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-success"
                    @onclick="ExportCsvAsync"
                    disabled="@_isExporting">
                @if (_isExporting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <span>匯出中...</span>
                }
                else
                {
                    <i class="bi bi-file-earmark-spreadsheet me-1"></i>
                    <span>匯出 CSV</span>
                }
            </button>
        </div>
    </div>

    <!-- 篩選區 -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">狀態</label>
                    <select class="form-select" @bind="_filterStatus" @bind:after="ApplyFilters">
                        <option value="">全部</option>
                        <option value="待處理">待處理</option>
                        <option value="進行中">進行中</option>
                        <option value="已完成">已完成</option>
                        <option value="已取消">已取消</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">優先級</label>
                    <select class="form-select" @bind="_filterPriority" @bind:after="ApplyFilters">
                        <option value="">全部</option>
                        <option value="高">高</option>
                        <option value="中">中</option>
                        <option value="低">低</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">負責人</label>
                    <input type="text" class="form-control" placeholder="搜尋負責人..."
                           @bind="_filterAssignee" @bind:after="ApplyFilters" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">關鍵字</label>
                    <input type="text" class="form-control" placeholder="搜尋任務名稱..."
                           @bind="_filterKeyword" @bind:after="ApplyFilters" />
                </div>
            </div>
        </div>
    </div>

    <!-- 任務列表 -->
    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">載入中...</span>
            </div>
        </div>
    }
    else if (!_filteredTasks.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            <span>沒有符合條件的任務</span>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>任務編號</th>
                                <th>任務名稱</th>
                                <th>狀態</th>
                                <th>優先級</th>
                                <th>負責人</th>
                                <th>所屬專案</th>
                                <th>截止日期</th>
                                <th>更新日期</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in _filteredTasks)
                            {
                                <tr>
                                    <td><code>@task.Id</code></td>
                                    <td>@task.Title</td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(task.Status)">
                                            @task.Status
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetPriorityBadgeClass(task.Priority)">
                                            @task.Priority
                                        </span>
                                    </td>
                                    <td>@task.AssigneeName</td>
                                    <td>@task.ProjectName</td>
                                    <td>@task.DueDate</td>
                                    <td>@task.UpdatedDate</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted">
                共 @_filteredTasks.Count 筆任務
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show align-items-center text-bg-danger border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">@_errorMessage</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        @onclick="() => _errorMessage = string.Empty"></button>
            </div>
        </div>
    </div>
}
