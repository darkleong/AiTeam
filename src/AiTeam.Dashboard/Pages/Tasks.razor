**檔案 5: src/AiTeam.Dashboard/Pages/Tasks.razor.cs**

```csharp
using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using AiTeam.Shared.Models;
using AiTeam.Shared.Services;
using Microsoft.AspNetCore.Components;
using Microsoft.Extensions.Logging;
using Microsoft.JSInterop;

namespace AiTeam.Dashboard.Pages
{
    public partial class Tasks
    {
        [Inject] private ICsvExportService CsvExportService { get; set; } = default!;
        [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
        [Inject] private ILogger<Tasks> Logger { get; set; } = default!;

        // 篩選條件
        private string _filterStatus = string.Empty;
        private string _filterPriority = string.Empty;
        private string _filterAssignee = string.Empty;
        private string _filterKeyword = string.Empty;

        // 狀態旗標
        private bool _isLoading = true;
        private bool _isExporting = false;
        private string _errorMessage = string.Empty;

        // 資料
        private List<TaskExportDto> _allTasks = new();
        private List<TaskExportDto> _filteredTasks = new();

        protected override async Task OnInitializedAsync()
        {
            await LoadTasksAsync();
        }

        private async Task LoadTasksAsync()
        {
            try
            {
                _isLoading = true;
                StateHasChanged();

                // TODO: 替換為實際的資料來源（API 呼叫或 Repository）
                _allTasks = await GetMockTasksAsync();
                ApplyFilters();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "載入任務列表失敗");
                _errorMessage = "載入任務列表失敗，請稍後再試。";
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }

        private void ApplyFilters()
        {
            var query = _allTasks.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_filterStatus))
                query = query.Where(t => t.Status == _filterStatus);

            if (!string.IsNullOrWhiteSpace(_filterPriority))
                query = query.Where(t => t.Priority == _filterPriority);

            if (!string.IsNullOrWhiteSpace(_filterAssignee))
                query = query.Where(t =>
                    t.AssigneeName.Contains(_filterAssignee, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(_filterKeyword))
                query = query.Where(t =>
                    t.Title.Contains(_filterKeyword, StringComparison.OrdinalIgnoreCase) ||
                    t.Description.Contains(_filterKeyword, StringComparison.OrdinalIgnoreCase));

            _filteredTasks = query.ToList();
        }

        private async Task ExportCsvAsync()
        {
            if (_isExporting) return;

            try
            {
                _isExporting = true;
                _errorMessage = string.Empty;
                StateHasChanged();

                Logger.LogInformation(
                    "開始匯出 CSV，共 {Count} 筆任務（篩選條件：狀態={Status}, 優先級={Priority}, 負責人={Assignee}, 關鍵字={Keyword}）",
                    _filteredTasks.Count,
                    _filterStatus,
                    _filterPriority,
                    _filterAssignee,
                    _filterKeyword);

                // 使用當前篩選後的任務資料產生 CSV
                var csvBytes = CsvExportService.ExportTasksToCsv(_filteredTasks);

                // 產生含時間戳記的檔名
                var fileName = $"任務列表_{DateTime.Now:yyyyMMdd_HHmmss}.csv";

                // 透過 JS Interop 觸發瀏覽器下載
                await TriggerFileDownloadAsync(fileName, "text/csv;charset=utf-8", csvBytes);

                Logger.LogInformation("CSV 匯出完成：{FileName}", fileName);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "CSV