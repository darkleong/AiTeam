@page "/rules"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>規則管理 - AI Team Dashboard</PageTitle>

<div class="page-header">
    <h2>規則管理</h2>
    <button class="btn btn-primary" @onclick="ToggleCreateForm">
        @(_showCreateForm ? "✕ 取消新增" : "+ 新增規則")
    </button>
</div>

@if (_showCreateForm)
{
    <div class="agent-setting-card" style="margin-bottom:24px">
        <h4>新增規則</h4>
        <div class="form-group">
            <label>規則內容 <span style="color:red">*</span></label>
            <textarea class="form-control" @bind="_newContent" rows="3"
                      placeholder="例如：回應使用繁體中文，語氣專業但親切"></textarea>
        </div>
        <div class="form-group">
            <label>排序</label>
            <input type="number" class="form-control" @bind="_newSortOrder" style="width:100px" />
        </div>

        @if (_createError is not null)
        {
            <div class="alert alert-danger">@_createError</div>
        }

        <div class="agent-setting-actions">
            <button class="btn btn-primary" @onclick="CreateRuleAsync" disabled="@_isCreating">
                @(_isCreating ? "新增中..." : "確認新增")
            </button>
        </div>
    </div>
}

@if (_rules.Count == 0 && !_showCreateForm)
{
    <div class="empty-state">
        <div class="empty-state-icon">📋</div>
        <p class="empty-state-title">還沒有任何規則</p>
        <p class="empty-state-hint">點擊右上角「新增規則」來建立 CEO 的行為準則</p>
    </div>
}
else
{
    @foreach (var rule in _rules)
    {
        <div class="agent-setting-card">
            @if (_editingId == rule.Id)
            {
                <div class="form-group">
                    <textarea class="form-control" @bind="_editContent" rows="3"></textarea>
                </div>
                <div class="form-group" style="display:flex; align-items:center; gap:8px">
                    <label>排序：</label>
                    <input type="number" class="form-control" @bind="_editSortOrder" style="width:80px" />
                </div>
                <div style="display:flex; gap:8px; margin-top:8px">
                    <button class="btn btn-primary" @onclick="() => SaveEditAsync(rule.Id)">儲存</button>
                    <button class="btn btn-secondary" @onclick="CancelEdit">取消</button>
                </div>
            }
            else
            {
                <div class="agent-setting-header">
                    <span style="flex:1; font-size:0.9rem">@rule.Content</span>
                    <label class="active-toggle" title="@(rule.IsActive ? "點擊停用" : "點擊啟用")">
                        <input type="checkbox"
                               checked="@rule.IsActive"
                               @onchange="(e) => ToggleActiveAsync(rule, (bool)e.Value!)" />
                        <span class="toggle-label">@(rule.IsActive ? "啟用" : "停用")</span>
                    </label>
                </div>
                <div style="display:flex; gap:8px; margin-top:8px; align-items:center">
                    <span style="font-size:0.75rem; color:var(--color-text-secondary)">排序: @rule.SortOrder</span>
                    <button class="btn btn-secondary" style="font-size:0.8rem; padding:4px 10px"
                            @onclick="() => StartEdit(rule)">編輯</button>
                    <button class="btn btn-secondary" style="font-size:0.8rem; padding:4px 10px; color:var(--color-status-failed)"
                            @onclick="() => DeleteRuleAsync(rule.Id)">刪除</button>
                </div>
            }
        </div>
    }
}
