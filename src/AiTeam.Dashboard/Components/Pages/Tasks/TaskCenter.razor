@page "/tasks"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>任務中心 - AI Team Dashboard</PageTitle>

<div class="page-header">
    <h2>任務中心</h2>
    <div class="page-filters">
        <select @bind="_statusFilter" class="form-select">
            <option value="">全部狀態</option>
            <option value="pending">等待中</option>
            <option value="running">執行中</option>
            <option value="done">完成</option>
            <option value="failed">失敗</option>
        </select>
    </div>
</div>

<MudTable @ref="_tableRef"
          ServerData="LoadServerDataAsync"
          Dense="true"
          Hover="true"
          RowsPerPage="50"
          T="TaskItemDto"
          OnRowClick="OnRowClickAsync"
          RowClass="cursor-pointer">
    <HeaderContent>
        <MudTh>狀態</MudTh>
        <MudTh>任務標題</MudTh>
        <MudTh>Agent</MudTh>
        <MudTh>專案</MudTh>
        <MudTh>觸發來源</MudTh>
        <MudTh>建立時間</MudTh>
        <MudTh>完成時間</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><StatusBadge Status="@context.Status" /></MudTd>
        <MudTd>@context.Title</MudTd>
        <MudTd>@context.AssignedAgent</MudTd>
        <MudTd>@context.ProjectName</MudTd>
        <MudTd>@context.TriggeredBy</MudTd>
        <MudTd>@context.CreatedAt.ToString("yyyy/MM/dd HH:mm")</MudTd>
        <MudTd>@context.CompletedAt?.ToString("yyyy/MM/dd HH:mm")</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

<TaskLogDrawer @bind-IsOpen="@_isDrawerOpen"
               SelectedTask="@_selectedTask"
               Logs="@_selectedLogs" />
