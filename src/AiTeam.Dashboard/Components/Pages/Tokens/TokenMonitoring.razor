@page "/tokens"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@* Playwright CI trigger test *@

<PageTitle>Token 監控 - AI Team Dashboard</PageTitle>

<div class="page-header">
    <h2>Token 監控</h2>
    <div class="header-actions">
        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
            <MudButton Color="@(_period == "today" ? Color.Primary : Color.Default)"
                       OnClick="@(() => SetPeriodAsync("today"))">今日</MudButton>
            <MudButton Color="@(_period == "week" ? Color.Primary : Color.Default)"
                       OnClick="@(() => SetPeriodAsync("week"))">本週</MudButton>
            <MudButton Color="@(_period == "month" ? Color.Primary : Color.Default)"
                       OnClick="@(() => SetPeriodAsync("month"))">本月</MudButton>
        </MudButtonGroup>
    </div>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <!-- 上方：Agent 卡片 -->
    <MudGrid Class="mb-4">
        @foreach (var agent in _summary.AgentSummaries)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-1"><b>@agent.AgentName</b></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">@agent.Model</MudText>
                        <MudDivider Class="mb-2" />
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">Input</MudText>
                            <MudText Typo="Typo.body2">@agent.TotalInputTokens.ToString("N0")</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">Output</MudText>
                            <MudText Typo="Typo.body2">@agent.TotalOutputTokens.ToString("N0")</MudText>
                        </div>
                        <MudDivider Class="my-2" />
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2" Color="Color.Success"><b>預估費用</b></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Success"><b>$@agent.EstimatedCostUsd.ToString("F4")</b></MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
        @if (_summary.AgentSummaries.Count > 0)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="2" Style="border: 2px solid var(--mud-palette-primary);">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-1"><b>合計</b></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">所有 Agent</MudText>
                        <MudDivider Class="mb-2" />
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">Input</MudText>
                            <MudText Typo="Typo.body2">@_summary.AgentSummaries.Sum(a => a.TotalInputTokens).ToString("N0")</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">Output</MudText>
                            <MudText Typo="Typo.body2">@_summary.AgentSummaries.Sum(a => a.TotalOutputTokens).ToString("N0")</MudText>
                        </div>
                        <MudDivider Class="my-2" />
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2" Color="Color.Primary"><b>預估費用</b></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Primary"><b>$@_summary.AgentSummaries.Sum(a => a.EstimatedCostUsd).ToString("F4")</b></MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

    <!-- 中間：折線圖 -->
    @if (_chartSeries.Length > 0)
    {
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">每日 Token 用量</MudText>
            <MudChart ChartType="ChartType.Line"
                      ChartSeries="@(_chartSeries.ToList())"
                      XAxisLabels="@_chartLabels"
                      Width="100%"
                      Height="300px"
                      ChartOptions="@_chartOptions" />
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">此時間區間尚無 Token 用量記錄。</MudAlert>
    }

    <!-- 底部：詳細表格 -->
    <MudTable Items="@_summary.AgentSummaries"
              Dense="true"
              Hover="true"
              SortLabel="排序"
              Elevation="2"
              T="TokenAgentSummaryDto">
        <ToolBarContent>
            <MudText Typo="Typo.h6">詳細用量</MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<TokenAgentSummaryDto, object>(x => x.AgentName)">Agent</MudTableSortLabel></MudTh>
            <MudTh>模型</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TokenAgentSummaryDto, object>(x => x.TotalInputTokens)">Input Tokens</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TokenAgentSummaryDto, object>(x => x.TotalOutputTokens)">Output Tokens</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TokenAgentSummaryDto, object>(x => x.EstimatedCostUsd)">預估費用 (USD)</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><b>@context.AgentName</b></MudTd>
            <MudTd><MudChip Size="Size.Small" T="string">@context.Model</MudChip></MudTd>
            <MudTd>@context.TotalInputTokens.ToString("N0")</MudTd>
            <MudTd>@context.TotalOutputTokens.ToString("N0")</MudTd>
            <MudTd>$@context.EstimatedCostUsd.ToString("F4")</MudTd>
        </RowTemplate>
    </MudTable>
}
