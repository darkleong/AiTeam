
```csharp
@page "/reviewer-agent"
@using AiTeam.Dashboard.Models
@using AiTeam.Dashboard.Services
@inject ReviewerAgentService ReviewerAgentService

<PageTitle>Reviewer Agent</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold">Reviewer Agent</h2>
            <p class="text-muted">程式碼審查報告</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">載入中...</span>
            </div>
        </div>
    }
    else if (reviewReport == null)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            尚無審查報告資料。
        </div>
    }
    else
    {
        <!-- 報告標題資訊 -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark-code me-2"></i>
                        @reviewReport.Title
                    </h5>
                    <span class="badge bg-light text-dark">@reviewReport.ReviewDate.ToString("yyyy/MM/dd HH:mm")</span>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p class="mb-1"><strong>審查者：</strong>@reviewReport.Reviewer</p>
                        <p class="mb-1"><strong>分支：</strong>@reviewReport.Branch</p>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1"><strong>Commit：</strong>@reviewReport.CommitHash</p>
                        <p class="mb-1"><strong>檔案數：</strong>@reviewReport.TotalFiles</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- 審查項目列表 -->
        @if (reviewReport.Items != null && reviewReport.Items.Any())
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-list-ul me-2"></i>審查項目</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 80px;">類型</th>
                                    <th style="width: 200px;">檔案</th>
                                    <th style="width: 80px;">行號</th>
                                    <th>問題描述</th>
                                    <th style="width: 120px;">建議</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in reviewReport.Items)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @GetBadgeClass(item.Severity)">
                                                @item.Severity
                                            </span>
                                        </td>
                                        <td class="text-truncate" style="max-width: 200px;" title="@item.FilePath">
                                            <code class="small">@item.FilePath</code>
                                        </td>
                                        <td>
                                            @if (item.LineNumber.HasValue)
                                            {
                                                <span class="text-muted small">L@item.LineNumber</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">-</span>
                                            }
                                        </td>
                                        <td>@item.Description</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Suggestion))
                                            {
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => ToggleSuggestion(item)"
                                                        title="查看建議">
                                                    <i class="bi bi-lightbulb"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                    @if (item.ShowSuggestion && !string.IsNullOrEmpty(item.Suggestion))
                                    {
                                        <tr class="table-warning">
                                            <td colspan="5" class="ps-4">
                                                <div class="d-flex align-items-start">
                                                    <i class="bi bi-lightbulb-fill text-warning me-2 mt-1"></i>
                                                    <div>
                                                        <strong class="small">建議：</strong>
                                                        <p class="mb-0 small">@item.Suggestion</p>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- 問題總結統計行 -->
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h6 class="mb-0">
                    <i class="bi bi-bar-chart-fill me-2"></i>
                    問題總結統計
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <!-- Bug -->
                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="card border-danger h-100">
                            <div class="card-body text-center p-3">
                                <div class="display-6 fw-bold text-danger">
                                    @reviewReport.Statistics.BugCount
                                </div>
                                <div class="d-flex align-items-center justify-content-center mt-1">
                                    <span class="badge bg-danger me-1">Bug</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Warning -->
                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="card border-warning h-100">
                            <div class="card-body text-center p-3">
                                <div class="display-6 fw-bold text-warning">
                                    @reviewReport.Statistics.WarningCount
                                </div>
                                <div class="d-flex align-items-center justify-content-center mt-1">
                                    <span class="badge bg-warning text-dark me-1">Warning</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Info -->
                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="card border-info h-100">
                            <div class="card-body text-center p-3">
                                <div class="display-6 fw-bold text-info">
                                    @reviewReport.Statistics.InfoCount
                                </div>
                                <div class="d-flex align-items-center justify-content-center mt-1">
                                    <span class="badge bg-info text-dark me-1">Info</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Suggestion -->
                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="card border-success h-100">
                            <div class="card-body text-center p-3">
                                <div class="display-6 fw-bold text-success">
                                    @reviewReport.Statistics.SuggestionCount
                                </div>
                                <div class="d-flex align-items-center justify-content-center mt-1">
                                    <span class="badge bg-success me-1">Suggestion</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Critical -->
                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="card border-dark h-100">
                            <div class="card-body text-center p-3">
                                <div class="display-6 fw-bold text-dark">
                                    @reviewReport.Statistics.CriticalCount
                                </div>
                                <div class="d-flex align-items-center justify-content-center mt-1">
                                    <span class="badge bg-dark me-1">Critical</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Total -->
                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="card border-secondary h-100">
                            <div class="card-body text-center p-3">
                                <div class="display-6 fw-bold text-secondary">
                                    @reviewReport.Statistics.TotalCount
                                </div>
                                <div class="d-flex align-items-center justify-content-center mt-1">
                                    <span class="badge bg-secondary me-1">Total</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 統計摘要列 -->
                <div class="table-responsive">
                    <table class="table table-bordered table-sm mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center">類型</th>
                                <th class="text-center">數量</th>
                                <th class="text-center">佔比</th>
                                <th class="text-center">嚴重程度</th>
                                <th>說明</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stat in GetStatisticsRows())
                            {
                                <tr>
                                    <td class="text-center">
                                        <span class="badge @stat.BadgeClass">@stat.Label</span>
                                    </td>
                                    <td class="text-center fw-bold @stat.TextClass">@stat.Count</td>
                                    <td class="text-center">
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1 me-2" style="height: 8px;">
                                                <div class="progress-bar @stat.ProgressClass"
                                                     role="progressbar"
                                                     style="width: @stat.Percentage%"
                                                     aria-valuenow="@stat.Percentage"
                                                     aria-valuemin="0"
                                                     aria-valuemax="100">
                                                </div>
                                            </div>
                                            <span class="small text-muted" style="min-width: 40px;">@stat.Percentage.ToString("F1")%</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @for (int i = 0; i < stat.SeverityLevel; i++)
                                        {
                                            <i class="bi bi-exclamation-circle-fill @stat.TextClass"></i>
                                        }
                                    </td>
                                    <td class="small text-muted">@stat.Description</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary">
                            <tr>
                                <td class="fw-bold">合計</td>
                                <td class="text-center fw-bold">@reviewReport.Statistics.TotalCount</td>
                                <td class="text-center">100%</td>
                                <td colspan="2" class="small text-muted">
                                    審查完成時間：@reviewReport.ReviewDate.ToString("yyyy/MM/dd HH:mm:ss")
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- 整體評分 -->
                <div class="mt-3 p-3 rounded @GetOverallStatusClass()">
                    <div class="d-flex align-items-center">
                        <i class="bi @GetOverallStatusIcon() fs-4 me-3"></i>
                        <div>
                            <h6 class="mb-0">@GetOverallStatusText()</h6>
                            <small class="opacity-75">@GetOverallStatusDescription()</small>
                        </div>
                        <div class="ms-auto">
                            <span class="badge bg-light text-dark fs-6">
                                評分：@reviewReport.Statistics.OverallScore / 100
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private ReviewReport? reviewReport;

    protected override async Task OnInitializedAsync()
    {
        await LoadReviewReport();
    }

    private async Task LoadReviewReport()
    {
        isLoading = true;
        try
        {
            reviewReport = await ReviewerAgentService.GetLatestReportAsync();
            if (reviewReport != null)
            {
                reviewReport.Statistics = ReviewerAgentService.CalculateStatistics(reviewReport);
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"載入審查報告失敗: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleSuggestion(ReviewItem item)
    {
        item.ShowSuggestion = !item.ShowSuggestion;
    }

    private string GetBadgeClass(string severity)
    {
        return severity?.ToLower() switch
        {
            "bug" => "bg-danger",
            "critical" => "bg-dark",
            "warning" => "bg-warning text-dark",
            "info" => "bg-info text-dark",
            "suggestion" => "bg-success",
            _ => "bg-secondary"
        };
    }

    private IEnumerable<StatisticsRow> GetStatisticsRows()
    {
        if (reviewReport?.Statistics == null)
            yield break;

        var stats = reviewReport.Statistics;
        int total = stats.TotalCount > 0 ? stats.TotalCount : 1;

        yield return new StatisticsRow
        {
            Label = "Critical",
            Count = stats.CriticalCount,
            Percentage = (double)stats.CriticalCount / total * 100,
            BadgeClass = "bg-dark",
            TextClass = "text-dark",
            ProgressClass = "bg-dark",
            SeverityLevel = 5,
            Description = "嚴重