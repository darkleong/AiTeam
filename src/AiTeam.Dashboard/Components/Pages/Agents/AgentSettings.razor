@page "/agents"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Agent 設定 - AI Team Dashboard</PageTitle>

<div class="page-header">
    <h2>Agent 設定</h2>
    <div style="display:flex; gap:8px">
        <button class="btn btn-primary" @onclick="() => _showCreateForm = !_showCreateForm">
            @(_showCreateForm ? "✕ 取消新增" : "+ 新增 Agent")
        </button>
        @if (_showRestartConfirm)
        {
            <button class="btn btn-secondary" style="color:var(--color-status-failed)"
                    @onclick="RestartBotAsync" disabled="@_isRestarting">
                @(_isRestarting ? "重啟中..." : "確認重啟")
            </button>
            <button class="btn btn-secondary" @onclick="() => _showRestartConfirm = false">取消</button>
        }
        else
        {
            <button class="btn btn-secondary" @onclick="() => _showRestartConfirm = true">
                ↺ 重啟 Bot
            </button>
        }
    </div>
</div>

@if (_showCreateForm)
{
    <div class="agent-setting-card" style="margin-bottom:24px">
        <h4>新增 Agent</h4>

        <div class="form-group">
            <label>名稱 <span style="color:red">*</span></label>
            <input class="form-control" @bind="_newName" placeholder="例如：Analytics" />
        </div>
        <div class="form-group">
            <label>描述</label>
            <input class="form-control" @bind="_newDescription" placeholder="簡述此 Agent 的職責" />
        </div>
        <div class="form-group">
            <label>信任等級：<strong>Lv@_newTrustLevel</strong></label>
            <MudSlider Value="@_newTrustLevel"
                       ValueChanged="@((int v) => _newTrustLevel = v)"
                       Min="0" Max="3" Step="1"
                       Style="width:200px" />
        </div>

        @if (_createError is not null)
        {
            <div class="alert alert-danger">@_createError</div>
        }

        <div class="agent-setting-actions">
            <button class="btn btn-primary" @onclick="CreateAgentAsync" disabled="@_isCreating">
                @(_isCreating ? "新增中..." : "確認新增")
            </button>
        </div>
    </div>
}

@if (_loadError is not null)
{
    <div class="alert alert-danger">
        <strong>載入失敗：</strong>@_loadError
    </div>
}
else if (_agents.Count == 0)
{
    <div class="alert alert-info">
        尚未載入 Agent 資料，請確認 Bot 服務已啟動並重新整理頁面。
    </div>
}

@foreach (var agent in _agents)
{
    <div class="agent-setting-card">
        <div class="agent-setting-header">
            <h4>@agent.Name</h4>
            <span class="team-label">@agent.TeamName</span>
            <label class="active-toggle" title="@(agent.IsActive ? "點擊停用" : "點擊啟用")">
                <input type="checkbox"
                       checked="@agent.IsActive"
                       @onchange="(e) => ToggleIsActiveAsync(agent, (bool)e.Value!)" />
                <span class="toggle-label">@(agent.IsActive ? "啟用中" : "已停用")</span>
            </label>
        </div>

        @if (!string.IsNullOrEmpty(agent.Description))
        {
            <p class="agent-description text-muted">@agent.Description</p>
        }

        <div class="trust-level-control">
            <label>信任等級：<strong>Lv@_trustLevels[agent.Id]</strong></label>
            <MudSlider Value="@_trustLevels[agent.Id]"
                       ValueChanged="@((int v) => _trustLevels[agent.Id] = v)"
                       Min="0" Max="3" Step="1"
                       Style="width:200px" />
        </div>

        <div class="agent-setting-actions">
            <button class="btn btn-primary"
                    @onclick="() => SaveTrustLevelAsync(agent)"
                    disabled="@_isSaving">
                @(_isSaving ? "儲存中..." : "儲存信任等級")
            </button>
        </div>
    </div>
}

@if (_saveMessage is not null)
{
    <div class="alert alert-success">@_saveMessage</div>
}

<hr style="margin: 32px 0; border-color: var(--color-border)" />

<h3 style="margin-bottom:16px">系統設定</h3>

<div class="agent-setting-card">
    <div class="agent-setting-header">
        <div>
            <strong>跳過 CEO 派工確認</strong>
            <p style="font-size:0.85rem; color:var(--color-text-secondary); margin:4px 0 0">
                啟用後，老闆下指令時將直接進入 Agent 執行確認，省略 CEO 決策 Embed。<br/>
                建議 CEO 準確率穩定後再開啟。修改後 5 分鐘內自動生效，免重啟 Bot。
            </p>
        </div>
        <label class="active-toggle">
            <input type="checkbox"
                   checked="@_skipCeoConfirm"
                   @onchange="OnSkipCeoConfirmChanged" />
            <span class="toggle-label">@(_skipCeoConfirm ? "啟用" : "停用")</span>
        </label>
    </div>
</div>
