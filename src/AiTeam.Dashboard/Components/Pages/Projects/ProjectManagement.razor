@page "/projects"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>專案管理 - AI Team Dashboard</PageTitle>

<div class="page-header">
    <h2>專案管理</h2>
    <button class="btn btn-primary" @onclick="ToggleCreateForm">
        @(_showCreateForm ? "✕ 取消新增" : "+ 新增專案")
    </button>
</div>

@if (_showCreateForm)
{
    <div class="agent-setting-card" style="margin-bottom:24px">
        <h4>新增專案</h4>

        <div class="form-group">
            <label>專案名稱 <span style="color:red">*</span></label>
            <input class="form-control" @bind="_newName" placeholder="例如：AiTeam" />
        </div>
        <div class="form-group">
            <label>Repo URL</label>
            <input class="form-control" @bind="_newRepoUrl" placeholder="https://github.com/owner/repo" />
        </div>
        <div class="form-group">
            <label>技術棧</label>
            <textarea class="form-control" @bind="_newTechStack" rows="3"
                      placeholder=".NET 10, Blazor Server, PostgreSQL, Docker"></textarea>
        </div>

        @if (_createError is not null)
        {
            <div class="alert alert-danger">@_createError</div>
        }

        <div class="agent-setting-actions">
            <button class="btn btn-primary" @onclick="CreateProjectAsync" disabled="@_isCreating">
                @(_isCreating ? "新增中..." : "確認新增")
            </button>
        </div>
    </div>
}

<MudTable Items="@_projects"
          Dense="true"
          Hover="true"
          RowsPerPage="50"
          T="ProjectDto"
          OnRowClick="OnRowClickAsync"
          RowClass="cursor-pointer">
    <HeaderContent>
        <MudTh>專案名稱</MudTh>
        <MudTh>團隊</MudTh>
        <MudTh>任務數</MudTh>
        <MudTh>啟用</MudTh>
        <MudTh>建立時間</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.TeamName</MudTd>
        <MudTd>@context.TaskCount</MudTd>
        <MudTd>
            <label @onclick:stopPropagation="true">
                <input type="checkbox"
                       checked="@context.IsActive"
                       @onchange="(e) => ToggleIsActiveAsync(context, (bool)e.Value!)" />
                @(context.IsActive ? "啟用" : "停用")
            </label>
        </MudTd>
        <MudTd>@context.CreatedAt.ToString("yyyy/MM/dd")</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
    <NoRecordsContent>
        <div class="empty-state">
            <div class="empty-state-icon">📁</div>
            <p class="empty-state-title">還沒有任何專案</p>
            <p class="empty-state-hint">點擊右上角「新增專案」建立第一個專案，讓任務可以正確關聯</p>
        </div>
    </NoRecordsContent>
</MudTable>

@if (_isDrawerOpen && _selectedProject is not null)
{
    <div class="slide-panel-overlay" @onclick="CloseDrawer"></div>
    <div class="slide-panel">
        <div class="drawer-header">
            <h4>@_selectedProject.Name</h4>
            <button class="btn-close" @onclick="CloseDrawer" aria-label="關閉">✕</button>
        </div>
        <div class="project-detail">
            <p><strong>團隊：</strong>@_selectedProject.TeamName</p>
            <p><strong>任務數量：</strong>@_selectedProject.TaskCount</p>
            <p>
                <strong>狀態：</strong>
                <label>
                    <input type="checkbox"
                           checked="@_selectedProject.IsActive"
                           @onchange="(e) => ToggleIsActiveAsync(_selectedProject, (bool)e.Value!)" />
                    @(_selectedProject.IsActive ? "啟用中" : "已停用")
                </label>
            </p>
            @if (_selectedProject.RepoUrl is not null)
            {
                <p><strong>Repo：</strong><a href="@_selectedProject.RepoUrl" target="_blank">@_selectedProject.RepoUrl</a></p>
            }
            @if (_selectedProject.TechStack is not null)
            {
                <div>
                    <strong>技術棧：</strong>
                    <pre>@_selectedProject.TechStack</pre>
                </div>
            }
            <p><strong>建立時間：</strong>@_selectedProject.CreatedAt.ToString("yyyy/MM/dd")</p>
        </div>
    </div>
}
