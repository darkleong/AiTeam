@page "/deployments"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>部署紀錄 - AI Team Dashboard</PageTitle>

<div class="page-header">
    <h2>部署紀錄</h2>
</div>

<TelerikGrid Data="@_deployments"
             TItem="TaskItemDto"
             Pageable="true"
             PageSize="50"
             Sortable="true"
             OnRowClick="@OnRowClickAsync">
    <GridColumns>
        <GridColumn Field="@nameof(TaskItemDto.Status)" Title="狀態" Width="100px">
            <Template>
                @{ var item = context as TaskItemDto; }
                <StatusBadge Status="@item!.Status" />
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(TaskItemDto.Title)"       Title="任務標題" />
        <GridColumn Field="@nameof(TaskItemDto.ProjectName)" Title="專案"    Width="150px" />
        <GridColumn Field="@nameof(TaskItemDto.CreatedAt)"   Title="部署時間" Width="160px" DisplayFormat="{0:yyyy/MM/dd HH:mm}" />
        <GridColumn Field="@nameof(TaskItemDto.CompletedAt)" Title="完成時間" Width="160px" DisplayFormat="{0:yyyy/MM/dd HH:mm}" />
    </GridColumns>
</TelerikGrid>

<TaskLogDrawer @bind-IsOpen="@_isDrawerOpen"
               SelectedTask="@_selectedTask"
               Logs="@_selectedLogs" />
