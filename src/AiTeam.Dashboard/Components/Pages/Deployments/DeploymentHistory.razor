@page "/deployments"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>部署紀錄 - AI Team Dashboard</PageTitle>

<div class="page-header">
    <h2>部署紀錄</h2>
</div>

<MudTable Items="@_deployments"
          Dense="true"
          Hover="true"
          RowsPerPage="50"
          T="TaskItemDto"
          OnRowClick="OnRowClickAsync"
          RowClass="cursor-pointer">
    <HeaderContent>
        <MudTh>狀態</MudTh>
        <MudTh>任務標題</MudTh>
        <MudTh>專案</MudTh>
        <MudTh>部署時間</MudTh>
        <MudTh>完成時間</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><StatusBadge Status="@context.Status" /></MudTd>
        <MudTd>@context.Title</MudTd>
        <MudTd>@context.ProjectName</MudTd>
        <MudTd>@context.CreatedAt.ToString("yyyy/MM/dd HH:mm")</MudTd>
        <MudTd>@context.CompletedAt?.ToString("yyyy/MM/dd HH:mm")</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

<TaskLogDrawer @bind-IsOpen="@_isDrawerOpen"
               SelectedTask="@_selectedTask"
               Logs="@_selectedLogs" />
