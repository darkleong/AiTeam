<!DOCTYPE html>
<html lang="zh-TW">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Team Dashboard</title>
    <base href="/" />
    <script>
        (function(){
            function applyTheme() {
                var t = localStorage.getItem('theme') || 'light';
                document.documentElement.dataset.theme = t;
                var btn = document.getElementById('theme-toggle-btn');
                if (btn) btn.textContent = t === 'dark' ? '☀' : '🌙';
            }
            function applySidebar() {
                var lw = document.getElementById('layout-wrapper');
                if (!lw) return;
                var collapsed = localStorage.getItem('sidebarCollapsed') === '1';
                lw.classList.toggle('sidebar-collapsed', collapsed);
                var btn = document.getElementById('sidebar-toggle-btn');
                if (btn) btn.textContent = collapsed ? '▶' : '◀';
            }
            // 立即套用主題，避免閃白
            applyTheme();
            // DOMContentLoaded 後套用主題圖示與側欄狀態
            document.addEventListener('DOMContentLoaded', function() { applyTheme(); applySidebar(); });
            // Blazor Enhanced Navigation 後重新套用（DOM 可能被 Blazor patch 重設）
            document.addEventListener('enhancedload', function() { applyTheme(); applySidebar(); });
            // MutationObserver 偵測 data-theme 被移除時立即還原
            new MutationObserver(function(ms) {
                for (var m of ms) {
                    if (m.attributeName === 'data-theme' && !document.documentElement.dataset.theme) {
                        applyTheme();
                    }
                }
            }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
        })();
    </script>
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="css/app.css" />
    <HeadOutlet />
</head>

<body>
    <CascadingAuthenticationState>
        <Router AppAssembly="@typeof(App).Assembly">
            <Found Context="routeData">
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                    <NotAuthorized>
                        @if (context.User.Identity?.IsAuthenticated != true)
                        {
                            <RedirectToLogin />
                        }
                        else
                        {
                            <p>您沒有權限存取此頁面。</p>
                        }
                    </NotAuthorized>
                </AuthorizeRouteView>
            </Found>
            <NotFound>
                <LayoutView Layout="@typeof(Layout.MainLayout)">
                    <p>找不到此頁面。</p>
                </LayoutView>
            </NotFound>
        </Router>
    </CascadingAuthenticationState>

    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
</body>

</html>
