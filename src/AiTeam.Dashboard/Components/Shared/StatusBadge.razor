@* 狀態 Badge 組件，顏色對應不同任務/Agent 狀態 *@

<span class="status-badge status-@Status.ToLower()">@GetLabel()</span>

@code {
    [Parameter, EditorRequired]
    public string Status { get; set; } = "";

    private string GetLabel() => Status switch
    {
        "pending"  => "等待中",
        "running"  => "執行中",
        "done"     => "完成",
        "failed"   => "失敗",
        "idle"     => "閒置",
        "error"    => "錯誤",
        _ => Status
    };
}
